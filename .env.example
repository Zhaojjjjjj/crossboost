# ===========================================
# CrossBoost Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ---- Database (MySQL) ----
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=crossboost
DB_PASSWORD=crossboost123
DB_DATABASE=crossboost

# ---- Redis ----
REDIS_URL=redis://:password@localhost:6379

# ---- JWT ----
JWT_SECRET=change-this-jwt-secret
INTERNAL_TOKEN=change-this-secret-token

# ---- AI Services ----
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=sk-your-anthropic-key
ANTHROPIC_BASE_URL=https://api.anthropic.com
GEMINI_API_KEY=
GROK_API_KEY=

# ---- S3 Storage ----
ASSETS_ENDPOINT=http://localhost:9000
ASSETS_BUCKET=crossboost
ASSETS_ACCESS_KEY=rustfsadmin
ASSETS_SECRET_KEY=rustfsadmin

# ---- Platform OAuth (TikTok Shop) ----
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# ---- Platform OAuth (Instagram) ----
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=

# ---- Platform OAuth (Pinterest) ----
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# ---- Platform OAuth (YouTube) ----
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
